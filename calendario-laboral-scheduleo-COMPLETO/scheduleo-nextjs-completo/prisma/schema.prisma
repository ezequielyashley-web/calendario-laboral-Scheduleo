// MODELO LogAuditoria - VERSIÓN ACTUALIZADA
// Reemplazar el modelo existente con este:

model LogAuditoria {
  id              String   @id @default(cuid())
  
  usuarioId       String?
  accion          String   // Descripción de la acción
  entidad         String   // Usuario, Vacacion, BajaMedica, etc.
  entidadId       String?
  
  detalles        Json?    // Detalles adicionales
  ipUsuario       String?
  
  // ============================================
  // NUEVO: TRACKING MULTIPLATAFORMA
  // ============================================
  platform        String?  // 'mobile_employee' | 'mobile_master' | 'desktop_master'
  userAgent       String?  // User agent completo del navegador
  screenWidth     Int?     // Ancho de pantalla en píxeles
  deviceInfo      String?  // Descripción amigable: "iPhone 13", "Windows PC", etc.
  // ============================================
  
  createdAt       DateTime @default(now())
  
  @@index([usuarioId])
  @@index([createdAt])
  @@index([entidad])
  @@index([platform])  // NUEVO: Índice para filtrar por plataforma
}

