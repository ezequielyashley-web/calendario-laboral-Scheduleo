// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                 @id @default(cuid())
  email               String                 @unique
  password            String
  name                String?
  role                String                 @default("EMPLEADO")
  empresaId           String?
  empresa             Empresa?               @relation(fields: [empresaId], references: [id])
  empleado            Empleado?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  passwordResetTokens PasswordResetToken[]
  mensajesEnviados   MensajePanelEjecutivo[] @relation("MensajesEnviados")
  mensajesRecibidos  MensajePanelEjecutivo[] @relation("MensajesRecibidos")

  @@index([empresaId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires   DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  @@index([userId])
}

model Empresa {
  id                        String                     @id @default(cuid())
  nombre                    String
  cif                       String                     @unique
  direccion                 String?
  telefono                  String?
  email                     String?
  users                     User[]
  empleados                 Empleado[]
  gruposTrabajo             GrupoTrabajo[]
  puestosDeTrabajo          PuestoDeTrabajo[]
  configuracionesCobertura  ConfiguracionCobertura[]
  libranzas                 Libranza[]
  bajas                     BajaMedica[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
}

model Empleado {
  id                  String          @id @default(cuid())
  userId              String          @unique
  user                User            @relation(fields: [userId], references: [id])
  empresaId           String
  empresa             Empresa         @relation(fields: [empresaId], references: [id])
  numeroEmpleado      String
  nombre              String
  apellidos           String
  dni                 String?
  telefono            String?
  naf                 String?
  iban                String?
  salario             Decimal?
  dniEnc              String          @default("")
  nafEnc              String          @default("")
  ibanEnc             String          @default("")
  telefonoEnc         String          @default("")
  salarioEnc          String          @default("")
  fechaNacimiento     DateTime?
  fechaContratacion   DateTime?
  grupoTrabajoId      String?
  grupoTrabajo        GrupoTrabajo?   @relation(fields: [grupoTrabajoId], references: [id])
  puestoDeTrabajoId   String?
  puestoDeTrabajo     PuestoDeTrabajo? @relation(fields: [puestoDeTrabajoId], references: [id])
  diasVacaciones      Int             @default(22)
  diasAsuntosPropios  Int             @default(6)
  esDemostracion      Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  fichajes            Fichaje[]
  vacaciones          Vacacion[]
  bajas               BajaMedica[]
  cambiosTurnoOrigen  CambioTurno[]   @relation("EmpleadoOrigen")
  cambiosTurnoDestino CambioTurno[]   @relation("EmpleadoDestino")
  gruposLibranza      EmpleadoGrupoLibranza[]

  @@unique([empresaId, numeroEmpleado])
  @@index([grupoTrabajoId])
  @@index([puestoDeTrabajoId])
}

model GrupoTrabajo {
  id          String      @id @default(cuid())
  empresaId   String
  empresa     Empresa     @relation(fields: [empresaId], references: [id])
  nombre      String
  descripcion String?
  color       String?
  empleados   Empleado[]
  libranzas   Libranza[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([empresaId, nombre])
}

model PuestoDeTrabajo {
  id                        String                     @id @default(cuid())
  empresaId                 String
  empresa                   Empresa                    @relation(fields: [empresaId], references: [id])
  nombre                    String
  descripcion               String?
  empleados                 Empleado[]
  configuracionesCobertura  ConfiguracionCobertura[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@unique([empresaId, nombre])
  @@index([empresaId])
}

model ConfiguracionCobertura {
  id                String          @id @default(cuid())
  empresaId         String
  empresa           Empresa         @relation(fields: [empresaId], references: [id])
  puestoDeTrabajoId String
  puestoDeTrabajo   PuestoDeTrabajo @relation(fields: [puestoDeTrabajoId], references: [id])
  coberturaMinimaL  Int             @default(0)
  coberturaMinimaM  Int             @default(0)
  coberturaMinimaX  Int             @default(0)
  coberturaMinimaJ  Int             @default(0)
  coberturaMinimaV  Int             @default(0)
  coberturaMinimaS  Int             @default(0)
  coberturaMinimaD  Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([empresaId, puestoDeTrabajoId])
  @@index([empresaId])
  @@index([puestoDeTrabajoId])
}

model Fichaje {
  id            String    @id @default(cuid())
  empleadoId    String
  empleado      Empleado  @relation(fields: [empleadoId], references: [id])
  fecha         DateTime
  horaEntrada   DateTime?
  horaSalida    DateTime?
  tipo          String    @default("NORMAL")
  observaciones String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([empleadoId])
  @@index([fecha])
}

model Vacacion {
  id              String    @id @default(cuid())
  empleadoId      String
  empleado        Empleado  @relation(fields: [empleadoId], references: [id])
  fechaInicio     DateTime
  fechaFin        DateTime
  diasTotales     Int
  estado          String    @default("PENDIENTE")
  observaciones   String?
  aprobadoPor     String?
  fechaAprobacion DateTime?
  esDemostracion  Boolean   @default(false)
  tipo            String    @default("LIBRE_ELECCION")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([empleadoId])
  @@index([estado])
}

model BajaMedica {
  id                        String    @id @default(cuid())
  empleadoId                String
  empleado                  Empleado  @relation(fields: [empleadoId], references: [id])
  empresaId                 String
  empresa                   Empresa   @relation(fields: [empresaId], references: [id])
  tipo                      String    @default("it_comun")
  estado                    String    @default("pendiente_confirmacion_inss")
  numeroParteINSS           String?
  fechaInicio               DateTime
  fechaFin                  DateTime?
  diasDuracion              Int?
  diagnostico               String?
  medico                    String?
  fechaRecepcionINSS        DateTime?
  confirmadaDatosEconomicos Boolean   @default(false)
  fechaConfirmacion         DateTime?
  confirmadoPorId           String?
  baseReguladora            Decimal?
  porcentajePrestacion      Int       @default(0)
  convenioCubre100          Boolean   @default(false)
  emailOrigen               String?
  emailAsunto               String?
  parteOficial              Json?
  creadoAutomaticamente     Boolean   @default(false)
  esDemostracion            Boolean   @default(false)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([empleadoId])
  @@index([estado])
}

model Libranza {
  id             String       @id @default(cuid())
  grupoTrabajoId String
  grupoTrabajo   GrupoTrabajo @relation(fields: [grupoTrabajoId], references: [id])
  empresaId      String
  empresa        Empresa      @relation(fields: [empresaId], references: [id])
  fecha          DateTime     @db.Date
  tipo           String       @default("COMPLETA")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([grupoTrabajoId])
  @@index([fecha])
}

model CambioTurno {
  id                String    @id @default(cuid())
  empleadoOrigenId  String
  empleadoOrigen    Empleado  @relation("EmpleadoOrigen", fields: [empleadoOrigenId], references: [id])
  empleadoDestinoId String
  empleadoDestino   Empleado  @relation("EmpleadoDestino", fields: [empleadoDestinoId], references: [id])
  fecha             DateTime
  turnoOrigen       String
  turnoDestino      String
  motivo            String?
  fechaOrigen       DateTime?
  fechaDestino      DateTime?
  tipo              String    @default("ENTRE_EMPLEADOS")
  estado            String    @default("PENDIENTE")
  validadoOrigen    Boolean   @default(false)
  validadoDestino   Boolean   @default(false)
  aprobadoPor       String?
  fechaAprobacion   DateTime?
  empresaId         String?
  esDemostracion    Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([empleadoOrigenId])
  @@index([empleadoDestinoId])
  @@index([estado])
}

model LogAuditoria {
  id        String   @id @default(cuid())
  userId    String
  accion    String
  entidad   String?
  entidadId String?
  detalles  String?
  ip        String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
  @@index([entidad])
}

model GrupoLibranza {
  id          String   @id @default(cuid())
  nombre      String
  color       String   @default("#6366f1")
  tipo        String   @default("ENTRE_SEMANA")
  descripcion String?
  empresaId   String?  @default("empresa-001")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dias      DiaLibranza[]
  empleados EmpleadoGrupoLibranza[]
}

model DiaLibranza {
  id              String        @id @default(cuid())
  grupoLibranzaId String
  grupoLibranza   GrupoLibranza @relation(fields: [grupoLibranzaId], references: [id], onDelete: Cascade)
  fecha           DateTime
  observacion     String?
  createdAt       DateTime      @default(now())

  @@index([grupoLibranzaId])
  @@index([fecha])
}

model EmpleadoGrupoLibranza {
  id              String        @id @default(cuid())
  empleadoId      String
  empleado        Empleado      @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  grupoLibranzaId String
  grupoLibranza   GrupoLibranza @relation(fields: [grupoLibranzaId], references: [id], onDelete: Cascade)
  fechaInicio     DateTime?     @default(now())
  fechaFin        DateTime?
  createdAt       DateTime      @default(now())

  @@index([empleadoId])
  @@index([grupoLibranzaId])
}

model MensajePanelEjecutivo {
  id             String   @id @default(cuid())
  remitenteId    String
  destinatarioId String
  texto          String
  createdAt      DateTime @default(now())
  remitente      User     @relation("MensajesEnviados", fields: [remitenteId], references: [id], onDelete: Cascade)
  destinatario   User     @relation("MensajesRecibidos", fields: [destinatarioId], references: [id], onDelete: Cascade)

  @@index([remitenteId])
  @@index([destinatarioId])
}
